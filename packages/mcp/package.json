{
  "name": "@akitaroh/marp-mcp",
  "version": "0.0.0",
  "description": "MCP server for MarpMaker - call Marp generation / rendering / visual validation from any MCP client (Claude Code / Desktop)",
  "license": "MIT",
  "author": "akitaroh",
  "type": "module",
  "bin": {
    "marp-mcp": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --config vite.board.config.ts && tsc",
    "build:board": "vite build --config vite.board.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/bin.ts",
    "dev": "tsx watch src/bin.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@akitaroh/marp-core": "workspace:*",
    "@marp-team/marp-core": "^4.3.0",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
